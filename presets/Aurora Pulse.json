    {"type": "bar_gauge", "name": "gpu_temperature", "x": 705, "y": 185, "width": 500, "height": 42, "color": "#7db8ff", "background_color": "#071526", "text": "GPU TEMP", "source": "gpu_temp", "font_size": 22, "rounded_corners": true, "gradient_fill": true},
