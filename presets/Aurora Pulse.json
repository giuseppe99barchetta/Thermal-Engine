    {"type": "line_chart", "name": "gpu_history", "x": 45, "y": 340, "width": 550, "height": 90, "color": "#86b7ff", "background_color": "#07101a", "background_color_opacity": 72, "text": "GPU", "source": "gpu_percent", "font_size": 18, "line_thickness": 3, "show_gradient": true, "smooth": true},
