    {"type": "rectangle", "name": "right_panel", "x": 660, "y": 40, "width": 580, "height": 400, "color": "#020a0d", "color_opacity": 66, "border_radius": 24, "source": "static"},
    {"type": "image", "name": "aurora_background", "x": 0, "y": 0, "width": 1280, "height": 480, "image_path": "assets/aurora-wide.jpg", "scale_proportionally": false, "source": "static"}
